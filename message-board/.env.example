PORT=6666
PUBLIC_BASE_URL=http://localhost:6666

# OAuth provider configuration
OAUTH_AUTHORIZATION_URL=https://your-oauth-provider.example/oauth/authorize
OAUTH_TOKEN_URL=https://your-oauth-provider.example/oauth/token
OAUTH_USERINFO_URL=https://your-oauth-provider.example/oauth/userinfo
OAUTH_CLIENT_ID=Y6pYAd2N2dvkDeaN
OAUTH_CLIENT_SECRET=replace-with-your-client-secret
OAUTH_REDIRECT_URI=http://localhost:6666/auth/callback
OAUTH_SCOPE=profile

# Session cookies
SESSION_SECRET=replace-with-a-long-random-secret
COOKIE_SECURE=false

# Moderation and safety
# Comma-separated QQ numbers that can open the review dashboard.
ADMIN_QQS=123456
# Comma-separated words blocked before content enters review.
BANNED_WORDS=赌博,诈骗,代考,外挂,色情,辱骂,暴力