PORT=6666
PUBLIC_BASE_URL=https://258.board.mrcwoods.com

# OAuth provider configuration
OAUTH_AUTHORIZATION_URL=https://your-oauth-provider.example/oauth/authorize
OAUTH_TOKEN_URL=https://your-oauth-provider.example/oauth/token
OAUTH_USERINFO_URL=https://your-oauth-provider.example/oauth/userinfo
OAUTH_CLIENT_ID=Y6pYAd2N2dvkDeaN
OAUTH_CLIENT_SECRET=replace-with-your-client-secret
OAUTH_REDIRECT_URI=https://258.board.mrcwoods.com/auth/callback
OAUTH_SCOPE=profile

# Session cookies
SESSION_SECRET=replace-with-a-long-random-secret
COOKIE_SECURE=true

# Moderation and safety
# Comma-separated QQ numbers that can open the review dashboard.
ADMIN_QQS=123456
# Comma-separated words blocked before content enters review (optional, AI will also check).
BANNED_WORDS=赌博,诈骗,代考,外挂,色情,辱骂,暴力

# AI Moderation (OpenAI-compatible API)
AI_MODERATION_ENABLED=true
AI_API_ENDPOINT=https://api.openai.com/v1/chat/completions
AI_API_KEY=sk-your-api-key-here
AI_MODEL=gpt-4o-mini

# AI Moderation retry settings
# Maximum retry attempts on failure (0 = no retry, default: 2)
AI_MAX_RETRIES=2
# Base delay between retries in ms (exponential backoff, default: 500)
AI_RETRY_BASE_DELAY_MS=500
# API request timeout in ms (default: 8000)
AI_TIMEOUT_MS=8000